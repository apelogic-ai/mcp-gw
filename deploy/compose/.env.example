GATEWAY_PORT=8080
# ApeLogic fork pin that includes MCP multi-provider auth support required by this gateway.
AGENTGATEWAY_IMAGE=ghcr.io/apelogic-ai/agentgateway:v1.1.0-apelogic.1

# HOP-1 Google OIDC for now. Okta can be added by changing issuer/audience/claims.
HOP1_PROFILE=google
HOP1_ISSUER=https://accounts.google.com
HOP1_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
HOP1_AUDIENCE=
HOP1_EMAIL_CLAIM=email
HOP1_SUBJECT_CLAIM=sub
# Optional replacement for the single-issuer HOP1_* values above.
# Example:
# HOP1_ISSUERS_JSON=[{"name":"google","issuer":"https://accounts.google.com","jwksUrl":"https://www.googleapis.com/oauth2/v3/certs","audiences":["<client-id>"],"emailClaim":"email","subjectClaim":"sub"}]
HOP1_ISSUERS_JSON=

# HOP-2 Google Workspace OAuth consent app.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://<dev-origin>/oauth/google/callback
# Optional comma/space-separated replacement for the generated full-parity consent scopes.
# Setting this narrower than the generated default intentionally disables some gws_* tools until
# users reconnect with a scope set that covers them.
GOOGLE_OAUTH_SCOPES=

# 32 random bytes, base64 encoded. Example:
#   openssl rand -base64 32
GOOGLE_TOKEN_ENCRYPTION_KEY=

GWS_BINARY_PATH=/app/node_modules/.bin/gws
TOKEN_STORE_DSN=postgres://mcp:mcp@token-store:5432/mcp

# Optional policy and durable audit.
# Optional local YAML policy file path inside the wrapper container. Mount it with a compose
# override when using Docker Compose, for example:
#   GOOGLE_WORKSPACE_POLICY_FILE=/etc/mcp-gw/policies/google-workspace-policy.yaml
GOOGLE_WORKSPACE_POLICY_FILE=
# Optional external Open Policy Agent endpoint. If both YAML and OPA are configured, the most
# restrictive decision wins.
OPA_POLICY_URL=
AUDIT_LOG_DIR=/var/log/mcp-gw
AUDIT_LOG_PATH=/var/log/mcp-gw/audit.jsonl
